# =============================================================================
# Visite Technique Platform — Environment Configuration
# Copy to .env and adjust values: cp .env.example .env
# =============================================================================

# --- Application ---
APP_NAME="Visite Technique Platform"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_TIMEZONE=Africa/Douala
APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_FR

# --- Logging ---
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# --- Database (Docker Compose defaults) ---
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=visite_technique
DB_USERNAME=visite
DB_PASSWORD=secret

# --- Session / Cache / Queue ---
SESSION_DRIVER=redis
SESSION_LIFETIME=120
CACHE_STORE=redis
QUEUE_CONNECTION=redis

# --- Redis (Docker Compose defaults) ---
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Mail (Mailpit in development) ---
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@visite-tech.local"
MAIL_FROM_NAME="${APP_NAME}"

# --- Filesystem ---
FILESYSTEM_DISK=local

# --- Twilio (global defaults; per-tenant overrides in center_settings) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WEBHOOK_AUTH_TOKEN=

# --- Phone normalization ---
DEFAULT_PHONE_COUNTRY=CM

# --- CSV import limits ---
CSV_MAX_FILE_SIZE_MB=10
CSV_MAX_ROWS=50000

# --- Notification defaults ---
DEFAULT_REMINDER_DAYS=30,15,7,1

# --- Horizon ---
HORIZON_PATH=horizon

# --- Backup (production) ---
BACKUP_DISK=local
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=
# AWS_BUCKET=

# --- Sentry (optional, production) ---
# SENTRY_LARAVEL_DSN=

# --- Vite ---
VITE_APP_NAME="${APP_NAME}"
