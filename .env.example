# =============================================================================
# Visite Notify — Environment Configuration
# Copy to .env and adjust values: cp .env.example .env
# =============================================================================

# --- Application ---
APP_NAME="Visite Notify"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Africa/Douala
APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_FR

# --- Logging ---
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# --- Database ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=visite_notify
DB_USERNAME=root
DB_PASSWORD=

# --- Session / Cache / Queue ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=redis
QUEUE_CONNECTION=redis

# --- Redis ---
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Mail ---
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@visite-notify.local"
MAIL_FROM_NAME="${APP_NAME}"

# --- Filesystem ---
FILESYSTEM_DISK=local

# --- Africa's Talking (SMS) ---
AFRICASTALKING_USERNAME=your_username
AFRICASTALKING_API_KEY=your_api_key
AFRICASTALKING_SENDER_ID=your_sender_id

# --- Meta WhatsApp Cloud API ---
META_WHATSAPP_TOKEN=your_meta_access_token
META_WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
META_WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
META_WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token

# --- Phone normalization ---
DEFAULT_PHONE_COUNTRY=CM

# --- CSV import limits ---
CSV_MAX_FILE_SIZE_MB=10
CSV_MAX_ROWS=50000

# --- Notification defaults ---
DEFAULT_REMINDER_DAYS=30,14,7,1

# --- Horizon ---
HORIZON_PATH=horizon

# --- Vite ---
VITE_APP_NAME="${APP_NAME}"
