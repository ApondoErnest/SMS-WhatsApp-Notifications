{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "app": "php artisan serve --host=127.0.0.1 --port=8001",
        "queue": "php artisan queue:work redis --queue=imports,default --tries=1 --timeout=300",
        "local": "concurrently -c \"#93c5fd,#a7f3d0,#f9a8d4\" --names=app,queue,vite \"npm:app\" \"npm:queue\" \"npm:dev\" --kill-others",
        "build": "vite build",
        "dev": "vite"
    },
    "devDependencies": {
        "@tailwindcss/forms": "^0.5.2",
        "@tailwindcss/vite": "^4.0.0",
        "autoprefixer": "^10.4.2",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^3.1",
        "postcss": "^8.4.31",
        "tailwindcss": "^4.3.0",
        "vite": "^8.0.0"
    }
}
